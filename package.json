{
  "name": "tft-advisor",
  "version": "1.1.0",
  "description": "TFT 云顶之弈助手 - 基于 DataTFT 大数据推荐",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "pack": "electron-packager . \"TFT Advisor\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "test": "node lcu.js"
  },
  "keywords": [
    "tft",
    "云顶之弈",
    "英雄联盟"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.tft.advisor",
    "productName": "TFT Advisor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TFT Advisor"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/.bin",
      "!dist/**"
    ]
  }
}
